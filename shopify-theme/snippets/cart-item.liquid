{%- comment -%}
  Usage: {% render 'cart-item', item: cart_item %}
{%- endcomment -%}

<div class="cart-item" data-key="{{ item.key }}">
  <img src="{{ item.image | img_url: '120x120', crop: 'center' }}" alt="{{ item.title }}" class="cart-item-image" referrerpolicy="no-referrer" loading="lazy" />

  <div class="cart-item-details">
    <h4 class="cart-item-title font-serif font-bold">{{ item.title }}</h4>
    {%- if item.variant_title -%}
      <p class="cart-item-variant">{{ item.variant_title }}</p>
    {%- endif -%}
    {%- if item.properties['_notes'] != blank -%}
      <p class="cart-item-notes">{{ item.properties['_notes'] }}</p>
    {%- endif -%}

    <div class="cart-item-controls">
      <div class="qty-controls">
        <button type="button" class="qty-btn" data-qty-change="{{ item.key }}" data-qty-delta="-1">-</button>
        <span class="qty-value">{{ item.quantity }}</span>
        <button type="button" class="qty-btn" data-qty-change="{{ item.key }}" data-qty-delta="1">+</button>
      </div>
      <span class="cart-item-price">AED {{ item.final_line_price | money_without_currency }}</span>
    </div>
  </div>

  <button type="button" class="cart-item-remove" data-remove-item="{{ item.key }}">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="3 6 5 6 21 6"></polyline>
      <path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"></path>
      <line x1="10" y1="11" x2="10" y2="17"></line>
      <line x1="14" y1="11" x2="14" y2="17"></line>
    </svg>
  </button>
</div>

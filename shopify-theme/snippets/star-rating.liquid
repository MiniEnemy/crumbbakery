{%- comment -%}
  Usage: {% render 'star-rating', rating: 5, size: 'sm' %}
{%- endcomment -%}
{%- assign size = size | default: 'sm' -%}
{%- if size == 'sm' -%}
  {%- assign star_size = 'w-3.5 h-3.5' -%}
{%- elsif size == 'md' -%}
  {%- assign star_size = 'w-5 h-5' -%}
{%- else -%}
  {%- assign star_size = 'w-6 h-6' -%}
{%- endif -%}

<div class="star-rating" aria-label="{{ rating }} out of 5 stars">
  {%- for i in (1..5) -%}
    {%- if i <= rating -%}
      <svg class="{{ star_size }} star filled" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
    {%- else -%}
      <svg class="{{ star_size }} star empty" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
    {%- endif -%}
  {%- endfor -%}
</div>

<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ page_description | default: shop.description | escape }}">

  <title>{{ page_title }} - Crumb &amp; Co. Bakery</title>

  {% if canonical_url != blank %}
    <link rel="canonical" href="{{ canonical_url }}">
  {% endif %}

  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400&family=Dancing+Script:wght@400;500;600;700&display=swap" rel="stylesheet">

  {{ 'theme.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'theme.js' | asset_url }}" defer></script>
  <script src="https://cdn.shopify.com/s/files/1/0533/2089/9508/t/54/assets/shop.js" defer></script>
</head>

<body class="template-{{ template.name | handle }}">
  <a class="skip-to-content" href="#MainContent">
    {{ 'general.accessibility.skip_to_content' | t }}
  </a>

  {% section 'header' %}

  {% if template.name == 'cart' or settings.enable_cart_drawer %}
    {% section 'cart-drawer' %}
  {% endif %}

  <main id="MainContent" class="main-content" role="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <script>
    window.theme = {
      strings: {
        cart: {{ 'sections.cart.title' | t | json }},
        addToCart: {{ 'products.product.add_to_cart' | t | json }},
        soldOut: {{ 'products.product.sold_out' | t | json }},
        unavailable: {{ 'products.product.unavailable' | t | json }},
        unavailableWithVariant: {{ 'products.product.value_unavailable' | t: 'option': '[value]' | json }}
      },
      moneyFormat: {{ shop.money_format | json }}
    };
  </script>
</body>
</html>

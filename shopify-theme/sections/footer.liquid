<footer class="site-footer">
  <!-- Newsletter section -->
  <div class="container-bakery footer-newsletter">
    <div class="newsletter-inner">
      <span class="section-accent font-accent">Saturday specials</span>
      <h3 class="newsletter-heading font-serif font-extrabold">Receive Our Warm Baking Recipes</h3>
      <p class="newsletter-desc">We send out Ellie's award-winning sourdough tips and details on limited Saturday morning cake specials once a week. No spam. Only sugar.</p>

      <form class="newsletter-form" action="/contact#newsletter" method="post">
        <input type="hidden" name="form_type" value="customer" />
        <input type="hidden" name="utf8" value="&#x2713;" />
        <input type="hidden" name="contact[tags]" value="newsletter" />
        <input type="email" name="contact[email]" required placeholder="rose@example.com" class="newsletter-input" />
        <button type="submit" class="newsletter-btn">
          Subscribe
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>
      </form>
      <p class="newsletter-success" id="newsletter-success" style="display:none">&#127881; Sourdough club registered! Flour magic is on the way!</p>
    </div>
  </div>

  <!-- Copyright bar -->
  <div class="container-bakery footer-bottom">
    <div class="footer-logo">
      <div class="footer-logo-text">
        <span class="text-xl">&#x1F9C1;</span>
        <span class="font-serif font-extrabold">Crumb &amp; Co.</span>
      </div>
      <p class="footer-copyright">&copy; {{ 'now' | date: "%Y" }} Crumb &amp; Co. Dubai. Hand-baked with love.</p>
    </div>

    <div class="footer-social">
      <span class="footer-social-label">Follow the Flour:</span>
      <a href="{{ section.settings.instagram_url | default: 'https://instagram.com' }}" target="_blank" rel="noreferrer" class="social-link" aria-label="Instagram">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"></path>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
        </svg>
      </a>
      <a href="{{ section.settings.facebook_url | default: 'https://facebook.com' }}" target="_blank" rel="noreferrer" class="social-link" aria-label="Facebook">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"></path>
        </svg>
      </a>
      <a href="mailto:{{ section.settings.email | default: 'hello@crumbandco.me' }}" class="social-link" aria-label="Email">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
          <polyline points="22,6 12,13 2,6"></polyline>
        </svg>
      </a>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "footer",
  "settings": [
    {
      "type": "text",
      "id": "instagram_url",
      "label": "Instagram URL",
      "default": "https://instagram.com"
    },
    {
      "type": "text",
      "id": "facebook_url",
      "label": "Facebook URL",
      "default": "https://facebook.com"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "hello@crumbandco.me"
    }
  ]
}
{% endschema %}

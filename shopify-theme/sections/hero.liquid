<section class="hero-section" id="bakes">
  <div class="hero-canvas-wrapper">
    <canvas id="hero-canvas" class="hero-canvas"></canvas>
  </div>

  <div class="container-bakery hero-content">
    <span class="hero-est font-accent">{{ section.settings.est_year }}</span>

    <h1 class="hero-title font-serif font-extrabold">
      {{ section.settings.heading }}
    </h1>

    <p class="hero-subtitle font-sans">
      {{ section.settings.subheading }}
    </p>

    <div class="hero-cta-group">
      <a href="#menu" class="btn-primary btn-bounce">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3l1.912 5.813a2 2 0 001.275 1.275L21 12l-5.813 1.912a2 2 0 00-1.275 1.275L12 21l-1.912-5.813a2 2 0 00-1.275-1.275L3 12l5.813-1.912a2 2 0 001.275-1.275L12 3z"/>
        </svg>
        Explore Daily Menu
      </a>
      <a href="#orders" class="btn-outline btn-bounce">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        Design Celebration Cake
      </a>
    </div>

    <div class="hero-badges">
      <span><span class="badge-dot badge-dot--secondary"></span> {{ section.settings.badge_1 }}</span>
      <span class="hero-badge-divider"><span class="badge-dot badge-dot--primary"></span> {{ section.settings.badge_2 }}</span>
      <span><span class="badge-dot badge-dot--secondary"></span> {{ section.settings.badge_3 }}</span>
    </div>
  </div>

  <div class="custom-divider"></div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Dubai's Favourite Little Craft Bakery"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Hand-kneaded organic sourdoughs, zesty morning buns, and custom buttercream creation cakes baked fresh in Dubai every morning."
    },
    {
      "type": "text",
      "id": "est_year",
      "label": "Established year",
      "default": "Est. 2017"
    },
    {
      "type": "text",
      "id": "badge_1",
      "label": "Badge 1",
      "default": "36-Hour Sourdoughs"
    },
    {
      "type": "text",
      "id": "badge_2",
      "label": "Badge 2",
      "default": "Heritage Organic Flour"
    },
    {
      "type": "text",
      "id": "badge_3",
      "label": "Badge 3",
      "default": "100% Preservative Free"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}

<section class="menu-section" id="menu">
  <div class="container-bakery">
    <div class="section-header">
      <span class="section-accent font-accent">bake list</span>
      <h2 class="section-title font-serif font-extrabold">Interactive Bakery Menu</h2>
      <div class="section-divider"></div>
      <p class="section-desc">Everything is baked strictly before sunrise using 100% natural, preservative-free sourdough cultures and flour mills.</p>
    </div>
    
    <!-- Filter toolbar -->
    <div class="filter-toolbar">
      <div class="filter-toolbar__row">
        <div class="filter-search">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input type="text" id="menu-search" placeholder="Search sourdough, lemon, buns, tea..." />
        </div>
        <div class="filter-diet">
          <span class="filter-diet__label"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="21" x2="14" y1="4" y2="4"/><line x1="10" x2="3" y1="4" y2="4"/><line x1="21" x2="12" y1="12" y2="12"/><line x1="8" x2="3" y1="12" y2="12"/><line x1="21" x2="16" y1="20" y2="20"/><line x1="12" x2="3" y1="20" y2="20"/><line x1="14" x2="14" y1="2" y2="6"/><line x1="8" x2="8" y1="10" y2="14"/><line x1="16" x2="16" y1="18" y2="22"/></svg> Filter Diet:</span>
          <button class="filter-pill active" data-diet="all">All Diets</button>
          <button class="filter-pill" data-diet="vegan">100% Plant-Based/Vegan</button>
          <button class="filter-pill" data-diet="slow-ferment">Slow-Ferment / Sourdoughs</button>
        </div>
      </div>
      <div class="filter-categories">
        <button class="category-tab active" data-category="all">All Items</button>
        <button class="category-tab" data-category="favourites">Daily Favourites</button>
        <button class="category-tab" data-category="loaves">Artisan Loaves</button>
        <button class="category-tab" data-category="buns">Sweet Buns</button>
        <button class="category-tab" data-category="muffins">Muffins &amp; Tarts</button>
        <button class="category-tab" data-category="celebration">Celebration Cakes</button>
      </div>
    </div>
    
    <!-- Product count -->
    <div class="menu-count" id="menu-count">Showing {{ section.blocks.size }} items</div>
    
    <!-- Product Grid -->
    <div class="product-grid" id="product-grid">
      {% for block in section.blocks %}
        {% if block.type == 'product' %}
          <div class="product-card hand-drawn-border"
               data-category="{{ block.settings.category }}"
               data-name="{{ block.settings.name | downcase }}"
               data-desc="{{ block.settings.description | downcase }}"
               data-tags="{{ block.settings.tags | downcase }}"
               data-is-fav="{{ block.settings.is_fav }}"
               data-price="{{ block.settings.price }}"
               data-image="{{ block.settings.image }}"
               data-id="{{ block.id }}"
               {{ block.shopify_attributes }}>
            
            <div class="product-card__image-wrap">
              <img src="{{ block.settings.image }}" alt="{{ block.settings.name }}" class="product-card__image" referrerpolicy="no-referrer" loading="lazy" />
              {% if block.settings.is_fav %}
                <span class="product-card__fave-badge">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg> Fave
                </span>
              {% endif %}
            </div>
            
            <div class="product-card__info">
              <h3 class="product-card__name font-serif font-extrabold">{{ block.settings.name }}</h3>
              <p class="product-card__desc">{{ block.settings.description }}</p>
              <div class="product-card__tags">
                {% assign tag_list = block.settings.tags | split: ',' %}
                {% for tag in tag_list %}
                  <span class="product-tag">{{ tag | strip }}</span>
                {% endfor %}
              </div>
            </div>
            
            <div class="product-card__footer">
              <span class="product-card__price font-serif font-black">AED {{ block.settings.price | times: 100 | money_without_currency }}</span>
              <button class="btn-primary-sm" data-open-modal="{{ block.id }}">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg> Customize
              </button>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Menu Section",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Interactive Bakery Menu" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "number", "id": "price", "label": "Price (AED)" },
        { "type": "select", "id": "category", "label": "Category", "options": [
          { "value": "favourites", "label": "Favourites" },
          { "value": "loaves", "label": "Loaves" },
          { "value": "buns", "label": "Buns" },
          { "value": "muffins", "label": "Muffins" },
          { "value": "celebration", "label": "Celebration" }
        ]},
        { "type": "text", "id": "tags", "label": "Tags (comma separated)" },
        { "type": "checkbox", "id": "is_fav", "label": "Is Favourite?" },
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Menu Section",
      "blocks": [
        { "type": "product", "settings": { "name": "Lemon Drizzle Loaf", "price": 2.80, "category": "favourites", "tags": "Zesty,Ellie's Pick,Best Seller", "is_fav": true } },
        { "type": "product", "settings": { "name": "Cinnamon Chelsea Bun", "price": 3.20, "category": "favourites", "tags": "Soft & Gooey,Rosie's Favourite", "is_fav": true } },
        { "type": "product", "settings": { "name": "Raspberry & Chocolate Muffin", "price": 3.00, "category": "favourites", "tags": "Fruity,Belgian Chocolate", "is_fav": true } },
        { "type": "product", "settings": { "name": "Sourdough Country Loaf", "price": 4.20, "category": "loaves", "tags": "Vegan,Slow Ferment,Local Grains" } },
        { "type": "product", "settings": { "name": "Rosemary & Sea Salt Sourdough", "price": 4.50, "category": "loaves", "tags": "Vegan,Herbaceous,Crowd Pleaser" } },
        { "type": "product", "settings": { "name": "Heritage Tea Loaf", "price": 3.80, "category": "loaves", "tags": "Nostalgic,Perfect with Tea" } },
        { "type": "product", "settings": { "name": "Cardamom & Orange Bun", "price": 3.40, "category": "buns", "tags": "Spiced,Aromatic" } },
        { "type": "product", "settings": { "name": "Pain au Chocolat", "price": 2.90, "category": "buns", "tags": "Flaky,Free-Range" } },
        { "type": "product", "settings": { "name": "Vanilla Bean Custard Tart", "price": 3.50, "category": "muffins", "tags": "Velvety,Sweet Treat" } },
        { "type": "product", "settings": { "name": "Classic Victoria Celebration Sponge", "price": 28.00, "category": "celebration", "tags": "Signature,Serves 8-10,Celebration" } },
        { "type": "product", "settings": { "name": "Decadent Triple Chocolate Layer", "price": 35.00, "category": "celebration", "tags": "Fudge,Serves 12-14,Dark & Rich" } }
      ]
    }
  ]
}
{% endschema %}